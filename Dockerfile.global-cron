# Minimal cron image — just Alpine + curl.
# Builds in seconds, ~10MB. No Node, no TypeScript, no npm install.
# Used by the nanoclaw-global-cron Railway service.
FROM alpine:3.19
RUN apk add --no-cache curl
CMD ["sh", "-c", "curl -sf -H \"Authorization: Bearer ${CRON_SECRET}\" \"${NANOCLAW_CLOUD_URL}/api/cron/tick\" && echo 'cron-tick: ok' || { echo 'cron-tick: failed'; exit 1; }"]
