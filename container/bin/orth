#!/usr/bin/env node

// src/orth.ts
import Orthogonal from "@orth/sdk";
import { appendFileSync, existsSync, mkdirSync } from "fs";
import { dirname } from "path";
var args = process.argv.slice(2);
function usage() {
  process.stderr.write(
    "Usage:\n  orth run <api> <path> [--query key=val ...] [--body json]\n  orth balance\n  orth usage [--limit N]\n  orth search <query>\n"
  );
}
function getApiKey() {
  const key = process.env.ORTHOGONAL_API_KEY;
  if (!key) {
    process.stderr.write("Error: ORTHOGONAL_API_KEY environment variable not set\n");
    process.exit(1);
  }
  return key;
}
function logCost(entry) {
  const costFile = process.env.DATA_COSTS_FILE || `${process.env.WORKSPACE_GROUP || "/workspace/group"}/.data-costs.jsonl`;
  const line = JSON.stringify({
    ts: (/* @__PURE__ */ new Date()).toISOString(),
    provider: "orthogonal",
    ...entry
  });
  try {
    const dir = dirname(costFile);
    if (!existsSync(dir)) mkdirSync(dir, { recursive: true });
    appendFileSync(costFile, line + "\n");
  } catch {
  }
}
async function cmdRun(api, path, rawArgs) {
  const query = {};
  let body;
  for (let i = 0; i < rawArgs.length; i++) {
    const flag = rawArgs[i];
    if (flag === "--query" || flag === "-q") {
      const kv = rawArgs[++i];
      if (!kv) {
        process.stderr.write("Error: --query requires key=value\n");
        process.exit(1);
      }
      const eq = kv.indexOf("=");
      if (eq < 1) {
        process.stderr.write(`Error: invalid --query format: ${kv}
`);
        process.exit(1);
      }
      query[kv.slice(0, eq)] = kv.slice(eq + 1);
    } else if (flag === "--body" || flag === "-d") {
      const raw = rawArgs[++i];
      if (!raw) {
        process.stderr.write("Error: --body requires JSON string\n");
        process.exit(1);
      }
      try {
        body = JSON.parse(raw);
      } catch {
        process.stderr.write("Error: --body value is not valid JSON\n");
        process.exit(1);
      }
    }
  }
  const orthogonal = new Orthogonal({ apiKey: getApiKey() });
  const response = await orthogonal.run({
    api,
    path,
    query: Object.keys(query).length > 0 ? query : void 0,
    body
  });
  logCost({ api, path, price_usd: response.price, success: response.success });
  process.stderr.write(`\u2713 ${api} ${path} \u2014 $${response.price}
`);
  process.stdout.write(JSON.stringify(response.data, null, 2) + "\n");
}
async function cmdBalance() {
  const res = await fetch("https://api.orth.sh/v1/credits/balance", {
    headers: { Authorization: `Bearer ${getApiKey()}` }
  });
  const data = await res.json();
  process.stdout.write(`Balance: ${data.balance ?? "unknown"}
`);
}
async function cmdUsage(rawArgs) {
  const limitIdx = rawArgs.indexOf("--limit");
  const limit = limitIdx >= 0 ? rawArgs[limitIdx + 1] : "20";
  const res = await fetch(`https://api.orth.sh/v1/credits/usage?limit=${limit}`, {
    headers: { Authorization: `Bearer ${getApiKey()}` }
  });
  const data = await res.json();
  process.stdout.write(JSON.stringify(data, null, 2) + "\n");
}
async function cmdSearch(query) {
  const res = await fetch("https://api.orth.sh/v1/search", {
    method: "POST",
    headers: { Authorization: `Bearer ${getApiKey()}`, "Content-Type": "application/json" },
    body: JSON.stringify({ prompt: query, limit: 10 })
  });
  const data = await res.json();
  if (!data.results) {
    process.stdout.write(JSON.stringify(data, null, 2) + "\n");
    return;
  }
  for (const r of data.results) {
    process.stdout.write(`${r.name} (${r.slug})
`);
    for (const ep of r.endpoints ?? []) {
      process.stdout.write(`  ${ep.path}${ep.description ? " \u2014 " + ep.description : ""}
`);
    }
  }
}
var cmd = args[0];
try {
  if (cmd === "run") {
    if (!args[1] || !args[2]) {
      usage();
      process.exit(1);
    }
    await cmdRun(args[1], args[2], args.slice(3));
  } else if (cmd === "balance") {
    await cmdBalance();
  } else if (cmd === "usage") {
    await cmdUsage(args.slice(1));
  } else if (cmd === "search") {
    if (!args[1]) {
      usage();
      process.exit(1);
    }
    await cmdSearch(args.slice(1).join(" "));
  } else {
    usage();
    process.exit(1);
  }
} catch (err) {
  process.stderr.write(`Error: ${err instanceof Error ? err.message : String(err)}
`);
  process.exit(1);
}
