#!/usr/bin/env bash
# orth — Orthogonal API CLI wrapper
# Usage:
#   orth run <api> <path> [--query key=val ...] [--body json]
#   orth balance
#   orth usage [--limit N]
#   orth search <query>
#
# Calls https://api.orth.sh/v1 and logs cost to .data-costs.jsonl
# Requires: ORTHOGONAL_API_KEY

set -euo pipefail

BASE_URL="https://api.orth.sh/v1"

die() { echo "error: $*" >&2; exit 1; }

[ -z "${ORTHOGONAL_API_KEY:-}" ] && die "ORTHOGONAL_API_KEY not set"

auth=(-H "Authorization: Bearer $ORTHOGONAL_API_KEY" -H "Content-Type: application/json")

log_cost() {
  local provider="orthogonal" api="${1:-}" path="${2:-}" price="${3:-0}" success="${4:-true}"
  local cost_file="${DATA_COSTS_FILE:-${WORKSPACE_GROUP:-/workspace/group}/.data-costs.jsonl}"
  local ts
  ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  echo "{\"ts\":\"$ts\",\"provider\":\"$provider\",\"api\":\"$api\",\"path\":\"$path\",\"price_usd\":\"$price\",\"success\":$success}" \
    >> "$cost_file" 2>/dev/null || true
}

# ── run ───────────────────────────────────────────────────────────────────────
cmd_run() {
  local api="${1:-}" path="${2:-}"
  [ -z "$api" ] || [ -z "$path" ] && { echo "Usage: orth run <api> <path> [--query k=v ...] [--body json]" >&2; exit 1; }
  shift 2

  local query_params="" body="{}"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --query|-q)
        local kv="${2:-}"
        [ -z "$kv" ] && die "--query requires key=value"
        local k="${kv%%=*}" v="${kv#*=}"
        query_params="$query_params&${k}=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$v'))" 2>/dev/null || echo "$v")"
        shift 2
        ;;
      --body|-d)
        body="${2:-}"
        [ -z "$body" ] && die "--body requires JSON string"
        shift 2
        ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  local url="$BASE_URL/run"
  local request_body
  request_body=$(jq -n \
    --arg api "$api" \
    --arg path "$path" \
    --argjson body "$body" \
    '{api: $api, path: $path, body: $body}')

  # Append query params if any
  if [ -n "$query_params" ]; then
    local qp="${query_params#&}"
    request_body=$(echo "$request_body" | jq --arg q "$qp" '. + {query_string: $q}')
  fi

  local tmp
  tmp=$(mktemp /tmp/orth_run_XXXXXX)
  local http_status
  http_status=$(curl -s -o "$tmp" -w "%{http_code}" -X POST "$url" "${auth[@]}" -d "$request_body") || true

  local response
  response=$(cat "$tmp"); rm -f "$tmp"

  local success="true"
  [[ "$http_status" -ge 400 ]] 2>/dev/null && success="false"

  local price
  price=$(echo "$response" | jq -r '.price // "0"' 2>/dev/null || echo "0")

  log_cost "$api" "$path" "$price" "$success"
  echo "$response" | jq '.data // .'
}

# ── balance ───────────────────────────────────────────────────────────────────
cmd_balance() {
  local tmp
  tmp=$(mktemp /tmp/orth_balance_XXXXXX)
  curl -s -o "$tmp" -X GET "$BASE_URL/credits/balance" "${auth[@]}" || true
  local response
  response=$(cat "$tmp"); rm -f "$tmp"
  echo "$response" | jq '.'
}

# ── usage ─────────────────────────────────────────────────────────────────────
cmd_usage() {
  local limit="20"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit) limit="${2:-20}"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  local tmp
  tmp=$(mktemp /tmp/orth_usage_XXXXXX)
  curl -s -o "$tmp" -X GET "$BASE_URL/credits/usage?limit=${limit}" "${auth[@]}" || true
  local response
  response=$(cat "$tmp"); rm -f "$tmp"
  echo "$response" | jq '.'
}

# ── search ────────────────────────────────────────────────────────────────────
cmd_search() {
  local query="$*"
  [ -z "$query" ] && { echo "Usage: orth search <query>" >&2; exit 1; }

  local body
  body=$(jq -n --arg q "$query" '{prompt: $q, limit: 10}')

  local tmp
  tmp=$(mktemp /tmp/orth_search_XXXXXX)
  curl -s -o "$tmp" -X POST "$BASE_URL/search" "${auth[@]}" -d "$body" || true
  local response
  response=$(cat "$tmp"); rm -f "$tmp"

  # Pretty-print: name (slug) + endpoints if available, else raw JSON
  if echo "$response" | jq -e '.results' > /dev/null 2>&1; then
    echo "$response" | jq -r '.results[] | "\(.name) (\(.slug))\n" + ((.endpoints // [])[] | "  \(.path)\(.description // "" | if . != "" then " — " + . else "" end)")'
  else
    echo "$response" | jq '.'
  fi
}

# ── main ──────────────────────────────────────────────────────────────────────
case "${1:-}" in
  run)    shift; cmd_run "$@" ;;
  balance) cmd_balance ;;
  usage)  shift; cmd_usage "$@" ;;
  search) shift; cmd_search "$@" ;;
  *)
    cat <<'USAGE'
orth — Orthogonal API CLI

Commands:
  run <api> <path> [--query k=v ...] [--body json]
        Call an Orthogonal data API endpoint
  balance
        Show current credit balance
  usage [--limit N]
        Show recent API usage (default: 20 entries)
  search <query>
        Search available APIs and endpoints

Examples:
  orth search "company firmographics"
  orth run apollo /search --query type=people --query name=John
  orth run clearbit /companies/find --query domain=stripe.com
  orth balance

Environment:
  ORTHOGONAL_API_KEY   (required) Orthogonal API key
USAGE
    exit 1
    ;;
esac
